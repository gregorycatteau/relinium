DJANGO_SECRET_KEY=change-me-local-only
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_SESSION_COOKIE_SECURE=false
DJANGO_CSRF_COOKIE_SECURE=false

# Auth/IAM Phase 1. Dev identity is disabled unless both RELINIUM_AUTH_MODE=dev
# and RELINIUM_DEV_AUTH_ENABLED=true are set explicitly.
RELINIUM_AUTH_MODE=disabled
RELINIUM_DEV_AUTH_ENABLED=false
RELINIUM_DEV_USER_EMAIL=dev@relinium.local
RELINIUM_DEV_USER_NAME=Relinium Dev
RELINIUM_DEV_USER_ROLE=owner
RELINIUM_DEFAULT_ORG=Relinium Local
RELINIUM_MFA_REQUIRED_DEFAULT=false

# PostgreSQL-only mode. No SQLite fallback exists.
RELINIUM_DATABASE_MODE=db
DATABASE_URL=postgresql://relinium_app:relinium_app_dev@127.0.0.1:5432/relinium_app

# If another local PostgreSQL already owns 127.0.0.1:5432, start the compose
# service with RELINIUM_POSTGRES_PORT=5433 and adjust DATABASE_URL accordingly.
# RELINIUM_POSTGRES_PORT=5433
# DATABASE_URL=postgresql://relinium_app:relinium_app_dev@127.0.0.1:5433/relinium_app
